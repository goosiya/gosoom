# ─────────────────────────────────────────────────────────────
# gosoom 루트 공통 환경변수 예시
# 실제 값은 각 앱의 .env / .env.local 에 채우고 커밋하지 않는다.
# ─────────────────────────────────────────────────────────────

# 웹(Next.js) → FastAPI 베이스 URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# 모바일(Expo) → FastAPI 베이스 URL
# Expo Go 실기기는 localhost 불가 → PC LAN IP 또는 배포 URL 사용(AR18)
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# 백엔드 시크릿은 apps/api/.env.example 참조 (DATABASE_URL, JWT_SECRET, CORS_ORIGINS)
