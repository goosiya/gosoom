# gosoom API 백엔드 환경변수 (apps/api/.env 로 복사 후 채움 — 절대 커밋 금지, NFR3)

# Railway PostgreSQL — async 드라이버(asyncpg) 형식.
# Railway가 주는 표준 URL(postgresql://...)에서 스킴만 postgresql+asyncpg:// 로 교체해 사용.
#   - 로컬 개발: Public Proxy URL (<host>.proxy.rlwy.net:<port>)
#   - Railway 런타임: Private URL (postgres.railway.internal:5432) — 서비스 Variables에 설정
# 예: postgresql+asyncpg://postgres:<password>@<host>.proxy.rlwy.net:<port>/railway
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/gosoom

# JWT 서명 시크릿 (HS256, AR11) — 충분히 긴 랜덤 문자열
JWT_SECRET=change-me-to-a-long-random-secret

# 액세스/리프레시 토큰 수명 (분 / 일)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS 허용 오리진 (AR14) — 콤마 구분, 운영에서 * 금지
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# 시드 관리자 (Story 1.3 / FR21) — `uv run python -m app.seed` 실행 시에만 사용.
# 회원가입/마이그레이션은 이 값 없이도 동작. 비밀번호는 평문 미보관(시드 시 Argon2 해싱).
SEED_ADMIN_EMAIL=admin@gosoom.local
SEED_ADMIN_PASSWORD=
SEED_ADMIN_DISPLAY_NAME=관리자
