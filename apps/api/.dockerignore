# Docker 빌드 컨텍스트 제외 — 이미지 슬림화 + 시크릿 유출 방지(AC3)
# 빌드 컨텍스트 = apps/api (Railway 루트 디렉터리)

# 가상환경/캐시 (이미지 안에서 uv sync로 재생성)
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# 시크릿 — 절대 이미지에 포함 금지(시크릿은 Railway 환경변수로만 주입)
.env
.env.*

# 테스트 (런타임 이미지 불요)
tests/

# 로컬/에디터 부산물
*.log
.DS_Store
